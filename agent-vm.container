[Unit]
Description=Agent VM (QEMU via toolbox)

[Container]
Image=quay.io/jbtrystram/toolbox
ContainerName=agent-vm
AutoUpdate=registry

# Pass through KVM device for hardware acceleration
AddDevice=/dev/kvm

# The QCOW2 disk image
Volume=%h/.local/share/agent-vm:/vm:Z

# UEFI firmware (read-only from host)
Volume=/usr/share/OVMF:/usr/share/OVMF:ro

# VM launch script
Volume=%h/.local/bin/launch-vm-agent.sh:/launch-vm.sh:ro,Z

# Forward SSH port (0.0.0.0 so other containers on the host can reach it)
PublishPort=9922:9922

Exec=/launch-vm.sh

[Service]
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
